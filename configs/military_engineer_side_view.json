{
  "globals": {
    "model": "sdxl",
    "num_streams": 1,
    "quantization": "none",
    "device": "auto"
  },
  "pipeline": [
    {
      "name": "engineer_base",
      "type": "text_to_image",
      "prompt": "Cyberpunk military engineer, side view, tactical armor, high-contrast neon lighting, Katana Zero aesthetic, detailed sprite art",
      "negative_prompt": "front view, blurry, low quality, distorted",
      "params": {
        "width": 768,
        "height": 768,
        "steps": 40,
        "guidance_scale": 7.5
      }
    },
    {
      "name": "segmentation",
      "type": "segmentation",
      "input_source": "engineer_base"
    }
  ],
  "layout": {
    "canvas_width": 768,
    "canvas_height": 768,
    "parts": [
      {"name": "head", "x": 0, "y": 0, "width": 128, "height": 128},
      {"name": "torso", "x": 128, "y": 0, "width": 128, "height": 128},
      {"name": "arm_left", "x": 256, "y": 0, "width": 128, "height": 128},
      {"name": "arm_right", "x": 384, "y": 0, "width": 128, "height": 128},
      {"name": "leg_left", "x": 0, "y": 128, "width": 128, "height": 128},
      {"name": "leg_right", "x": 128, "y": 128, "width": 128, "height": 128},
      {"name": "weapon", "x": 256, "y": 128, "width": 128, "height": 128}
    ]
  },
  "export": {
    "formats": ["png"],
    "output_dir": "./output"
  }
}
