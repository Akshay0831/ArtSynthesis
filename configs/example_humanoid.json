{
  "generation": {
    "model": "sdxl",
    "num_streams": 1,
    "seed_strategy": "design_variation",
    "enable_pause_resume": true,
    "enable_feedback": true,
    "enable_reference_search": true,
    "ip_adapter_mode": "dual"
  },
  "layout": {
    "canvas_width": 1024,
    "canvas_height": 1024,
    "parts": [
      {"name": "head", "x": 0, "y": 0, "width": 256, "height": 256},
      {"name": "torso", "x": 256, "y": 0, "width": 256, "height": 256},
      {"name": "upper_arm_l", "x": 512, "y": 0, "width": 128, "height": 256},
      {"name": "upper_arm_r", "x": 640, "y": 0, "width": 128, "height": 256},
      {"name": "lower_arm_l", "x": 768, "y": 0, "width": 128, "height": 256},
      {"name": "lower_arm_r", "x": 896, "y": 0, "width": 128, "height": 256},
      {"name": "upper_leg_l", "x": 0, "y": 256, "width": 128, "height": 256},
      {"name": "upper_leg_r", "x": 128, "y": 256, "width": 128, "height": 256},
      {"name": "lower_leg_l", "x": 256, "y": 256, "width": 128, "height": 256},
      {"name": "lower_leg_r", "x": 384, "y": 256, "width": 128, "height": 256},
      {"name": "weapon", "x": 512, "y": 256, "width": 256, "height": 256}
    ]
  },
  "prompts": {
    "hero": "Professional sci-fi character illustration",
    "negative": "blurry, low quality, distorted, deformed"
  },
  "export": {
    "formats": ["png", "depth", "metadata"],
    "output_dir": "./output"
  },
  "references": {
    "enable_search": true,
    "index_path": "./references"
  }
}
