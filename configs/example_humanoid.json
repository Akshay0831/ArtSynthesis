{
  "globals": {
    "model": "sdxl",
    "num_streams": 1,
    "quantization": "none",
    "device": "auto",
    "enable_multi_stream": true
  },
  "pipeline": [
    {
      "name": "base_character",
      "type": "text_to_image",
      "prompt": "Professional sci-fi humanoid character illustration, full body, cinematic lighting, high detail, concept art style",
      "negative_prompt": "blurry, low quality, distorted, deformed, extra limbs, overlapping parts",
      "params": {
        "width": 1024,
        "height": 1024,
        "steps": 30,
        "guidance_scale": 7.5
      }
    },
    {
      "name": "refinement",
      "type": "image_to_image",
      "input_source": "base_character",
      "prompt": "Highly detailed textures, polished surfaces, professional color grading",
      "params": {
        "strength": 0.3,
        "steps": 20
      }
    },
    {
      "name": "segmentation",
      "type": "segmentation",
      "input_source": "refinement"
    }
  ],
  "layout": {
    "canvas_width": 1024,
    "canvas_height": 1024,
    "parts": [
      {"name": "head", "x": 0, "y": 0, "width": 256, "height": 256},
      {"name": "torso", "x": 256, "y": 0, "width": 256, "height": 256},
      {"name": "upper_arm_l", "x": 512, "y": 0, "width": 128, "height": 256},
      {"name": "upper_arm_r", "x": 640, "y": 0, "width": 128, "height": 256},
      {"name": "lower_arm_l", "x": 768, "y": 0, "width": 128, "height": 256},
      {"name": "lower_arm_r", "x": 896, "y": 0, "width": 128, "height": 256},
      {"name": "upper_leg_l", "x": 0, "y": 256, "width": 128, "height": 256},
      {"name": "upper_leg_r", "x": 128, "y": 256, "width": 128, "height": 256},
      {"name": "lower_leg_l", "x": 256, "y": 256, "width": 128, "height": 256},
      {"name": "lower_leg_r", "x": 384, "y": 256, "width": 128, "height": 256},
      {"name": "weapon", "x": 512, "y": 256, "width": 256, "height": 256}
    ]
  },
  "export": {
    "formats": ["png"],
    "output_dir": "./output",
    "save_intermediate": true
  }
}
